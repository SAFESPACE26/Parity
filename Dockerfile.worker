FROM node:22-bookworm-slim

# GnuCOBOL (cobc/cobcrun) + Python 3 — required by the verification pipeline
RUN apt-get update && apt-get install -y \
    gnucobol \
    python3 \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

CMD ["npx", "tsx", "engine/worker.ts"]
